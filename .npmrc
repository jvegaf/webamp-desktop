# AIDEV-NOTE: shamefully-hoist is required for electron-builder compatibility.
# pnpm's default isolated node_modules structure (symlinks under .pnpm/) is not
# correctly followed by electron-builder when packaging the app, causing
# transitive dependencies (e.g. fs-extra, graceful-fs, semver) to be missing
# from the installed app. shamefully-hoist=true flattens node_modules like npm.
shamefully-hoist=true
